{
  "name": "gnurlies",
  "version": "0.1.2",
  "description": "Markdown-it plugin for gnurlies — Questache and Attaché inline AI collaboration syntax",
  "homepage": "https://github.com/tingham/gnurlies",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
